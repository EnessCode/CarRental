@model List<ResultAboutDto>

@{
    ViewData["Title"] = "Hakkımızda Listesi";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
    int count = 0;
}

<div class="container-fluid py-4">
    <div class="alert alert-info border-0 shadow-sm rounded-4 mb-4 d-flex align-items-center gap-3">
        <div class="bg-info p-2 rounded-3 text-white">
            <i class="ri-information-line fs-4"></i>
        </div>
        <div>
            <h6 class="fw-bold mb-0">Hakkımızda Yönetimi</h6>
            <small>Sitenin kurumsal vizyonunu anlatan bu bölüm için <strong>tek bir aktif kayıt</strong> olması yeterlidir. Mevcut kaydı güncelleyerek içeriği taze tutabilirsiniz.</small>
        </div>
    </div>
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-0 text-dark">
                            <i class="ri-team-line text-primary me-2"></i> Kurumsal Bilgiler
                        </h5>
                    </div>
                    @if (Model.Count == 0)
                    {
                        <a href="/Admin/About/CreateAbout" class="btn btn-primary rounded-pill px-4 shadow-primary">
                            <i class="ri-add-circle-line me-1"></i> Yeni Hakkımızda Ekle
                        </a>
                    }
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 text-muted fw-bold small text-uppercase" style="width: 80px;">#</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase">Görsel</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase">Başlık ve İçerik</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase text-center">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <td class="ps-4 fw-medium text-secondary">@count</td>
                                        <td>
                                            <div class="bg-light rounded-3 overflow-hidden border" style="width: 100px; height: 60px;">
                                                <img src="@item.ImageUrl" class="w-100 h-100 object-fit-cover" alt="About Image" onerror="this.src='/images/no-image.jpg'">
                                            </div>
                                        </td>
                                        <td>
                                            <div class="py-2">
                                                <div class="fw-bold text-dark fs-6">@item.Title</div>
                                                <div class="small text-muted text-truncate" style="max-width: 450px;">
                                                    @item.Description
                                                </div>
                                            </div>
                                        </td>
                                        <td class="text-center pe-4">
                                            <div class="d-flex justify-content-center gap-2">
                                                <a href="/Admin/About/UpdateAbout/@item.Id" class="btn btn-sm btn-outline-info rounded-circle p-2 border-0 shadow-sm" title="Güncelle">
                                                    <i class="ri-edit-2-line fs-5"></i>
                                                </a>
                                                <button onclick="deleteItem('@item.Id','About')" class="btn btn-sm btn-outline-danger rounded-circle p-2 border-0 shadow-sm" title="Sil">
                                                    <i class="ri-delete-bin-6-line fs-5"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                                @if (Model.Count == 0)
                                {
                                    <tr>
                                        <td colspan="4" class="text-center py-5 text-muted italic">
                                            <i class="ri-inbox-line fs-1 d-block mb-2"></i>
                                            Henüz hakkımızda yazısı eklenmemiş.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .object-fit-cover {
        object-fit: cover;
    }

    .shadow-primary {
        box-shadow: 0 10px 20px rgba(67, 97, 238, 0.2);
    }
</style>
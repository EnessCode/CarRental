@model UpdateCarDto

@{
    ViewData["Title"] = "Araç Bilgilerini Güncelle";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-info-soft p-2 rounded-3 text-info">
                            <i class="ri-edit-box-line fs-3"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0">Araç Bilgilerini Güncelle</h5>
                            <small class="text-muted">ID: #@Model.Id olan aracın bilgilerini düzenliyorsunuz.</small>
                        </div>
                    </div>
                </div>
                <form method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="card-body p-4 p-md-5">
                        <p class="card-subtitle mb-4 text-secondary">Lütfen güncellemek istediğiniz alanları değiştirin ve "Değişiklikleri Kaydet" butonuna tıklayın.</p>
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Araç Markası</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-price-tag-3-line"></i></span>
                                    @Html.DropDownListFor(x => x.BrandId, (List<SelectListItem>)ViewBag.BrandList, new { @class = "form-select border-start-0 py-2 shadow-none" })
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Model Adı</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-car-fill"></i></span>
                                    <input type="text" asp-for="Model" class="form-control border-start-0 py-2 shadow-none">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Kapak Görsel URL</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-image-line"></i></span>
                                    <input type="text" asp-for="CoverImageUrl" class="form-control border-start-0 py-2 shadow-none">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Büyük Görsel URL</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-image-fill"></i></span>
                                    <input type="text" asp-for="BigImageUrl" class="form-control border-start-0 py-2 shadow-none">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold small text-muted text-uppercase">Kilometre</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-dashboard-3-line"></i></span>
                                    <input type="number" asp-for="Kilometer" class="form-control border-start-0 py-2 shadow-none">
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold small text-muted text-uppercase">Vites Tipi</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-settings-3-line"></i></span>
                                    <select asp-for="Transmission" class="form-select border-start-0 py-2 shadow-none">
                                        <option value="Otomatik">Otomatik</option>
                                        <option value="Manuel">Manuel</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold small text-muted text-uppercase">Yakıt Tipi</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-gas-station-line"></i></span>
                                    <select asp-for="Fuel" class="form-select border-start-0 py-2 shadow-none">
                                        <option value="Dizel">Dizel</option>
                                        <option value="Benzin">Benzin</option>
                                        <option value="Hibrit">Hibrit</option>
                                        <option value="Elektrik">Elektrik</option>
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Bagaj Kapasitesi</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-briefcase-4-line"></i></span>
                                    <input type="number" asp-for="Luggage" class="form-control border-start-0 py-2 shadow-none">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Koltuk Sayısı</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-user-line"></i></span>
                                    <input type="number" asp-for="Seat" class="form-control border-start-0 py-2 shadow-none">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-light border-top p-4 d-flex justify-content-end gap-2">
                        <a href="/Admin/Car/Index" class="btn btn-light rounded-pill px-4">Vazgeç</a>
                        <button type="submit" class="btn btn-info text-white rounded-pill px-5 shadow-sm fw-bold">
                            <i class="ri-refresh-line me-2"></i> Değişiklikleri Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-info-soft {
        background-color: rgba(13, 202, 240, 0.1);
    }

    .input-group-text {
        color: #64748B;
        border-color: #E2E8F0;
    }

    .form-control:focus, .form-select:focus {
        border-color: #0dcaf0;
        box-shadow: 0 0 0 0.25rem rgba(13, 202, 240, 0.1);
    }
</style>
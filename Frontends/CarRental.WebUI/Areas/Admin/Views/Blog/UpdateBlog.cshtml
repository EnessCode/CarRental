@model UpdateBlogDto

@{
    ViewData["Title"] = "Blog Yazısını Güncelle";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="alert alert-info border-0 shadow-sm rounded-4 mb-4 d-flex align-items-center gap-3">
                <div class="bg-info p-2 rounded-3 text-white">
                    <i class="ri-edit-2-line fs-4"></i>
                </div>
                <div>
                    <h6 class="fw-bold mb-0">Düzenleme Modu</h6>
                    <small>Blog içeriğinde yapacağınız değişiklikler kaydedildiği an canlı sitede güncellenecektir.</small>
                </div>
            </div>
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-info-soft p-2 rounded-3 text-info">
                            <i class="ri-article-line fs-3"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0">Blog Yazısını Düzenle</h5>
                            <small class="text-muted">ID: #@Model.Id olan içeriği güncelliyorsunuz.</small>
                        </div>
                    </div>
                </div>
                <form asp-area="Admin" asp-controller="Blog" asp-action="UpdateBlog" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="CreatedAt" />
                    <input type="hidden" asp-for="AuthorId" />
                    <input type="hidden" asp-for="CategoryId" />
                    <div class="card-body p-4 p-md-5">
                        <div class="row g-4">
                            <div class="col-md-12">
                                <label class="form-label fw-bold small text-muted text-uppercase">Blog Başlığı</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-t-box-line text-info"></i></span>
                                    <input type="text" asp-for="Title" class="form-control border-start-0 py-2 shadow-none" placeholder="Etkileyici bir başlık giriniz...">
                                </div>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold small text-muted text-uppercase">Kapak Fotoğraf URL</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-image-line text-info"></i></span>
                                    <input type="text" asp-for="CoverImageUrl" class="form-control border-start-0 py-2 shadow-none" placeholder="https://image-url.com/blog.jpg">
                                </div>
                                <div class="mt-3">
                                    <small class="text-muted d-block mb-2">Mevcut Görsel Önizlemesi:</small>
                                    <img src="@Model.CoverImageUrl" class="rounded-3 border shadow-sm object-fit-cover" style="width: 200px; height: 120px;" onerror="this.src='/images/no-image.jpg'">
                                </div>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold small text-muted text-uppercase">Blog İçeriği</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0 align-items-start pt-2"><i class="ri-text-snippet text-info"></i></span>
                                    <textarea asp-for="Description" class="form-control border-start-0 py-2 shadow-none" rows="10" placeholder="Blog içeriğini buraya yazınız..."></textarea>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-light border-top p-4 d-flex justify-content-end gap-2">
                        <a href="/Admin/Blog/Index" class="btn btn-light rounded-pill px-4 fw-bold text-secondary">Vazgeç</a>
                        <button type="submit" class="btn btn-info text-white rounded-pill px-5 shadow-sm fw-bold">
                            <i class="ri-refresh-line me-2"></i> Değişiklikleri Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-info-soft {
        background-color: rgba(13, 202, 240, 0.1);
    }

    .input-group-text {
        border-color: #E2E8F0;
    }

    .form-control {
        border-color: #E2E8F0;
        font-size: 0.9rem;
    }

        .form-control:focus {
            border-color: #0dcaf0;
            box-shadow: 0 0 0 0.25rem rgba(13, 202, 240, 0.1);
        }

    .object-fit-cover {
        object-fit: cover;
    }
</style>
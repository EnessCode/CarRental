@model List<ResultAllBlogsWithAuthorDto>

@{
    ViewData["Title"] = "Blog Listesi";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
    int count = 0;
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-0 text-dark">
                            <i class="ri-article-fill text-primary me-2"></i> Blog Yazıları Yönetimi
                        </h5>
                        <small class="text-muted">Sistemdeki tüm haber, makale ve gezi rehberlerini buradan yönetebilirsiniz.</small>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 text-muted fw-bold small text-uppercase" style="width: 50px;">#</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase">Blog Başlığı</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase">Yazar</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase">Kategori</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase">Tarih</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase text-center">Yorumlar</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase text-center">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <td class="ps-4 fw-medium text-secondary">@count</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="position-relative">
                                                    <img src="@item.CoverImageUrl" class="rounded-3 object-fit-cover border" style="width: 60px; height: 45px;" alt="Blog Image" onerror="this.src='/images/no-image.jpg'">
                                                </div>
                                                <div style="max-width: 250px;">
                                                    <div class="fw-bold text-dark text-truncate">@item.Title</div>
                                                    <small class="text-muted d-block text-truncate">ID: #@item.Id</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="bg-soft-info p-1 rounded-circle" style="width: 24px; height: 24px; display:flex; align-items:center; justify-content:center;">
                                                    <i class="ri-user-3-line text-info small"></i>
                                                </div>
                                                <span class="small fw-medium text-secondary">@item.AuthorName</span>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-soft-primary text-primary rounded-pill px-3">
                                                @item.CategoryName
                                            </span>
                                        </td>
                                        <td>
                                            <div class="small text-secondary">
                                                <i class="ri-calendar-line me-1"></i> @item.CreatedAt.ToString("dd.MM.yyyy")
                                            </div>
                                        </td>
                                        <td class="text-center">
                                            <a href="/Admin/Comment/BlogCommentList/@item.Id" class="btn btn-sm btn-outline-warning rounded-pill px-3 border-0 shadow-sm fw-bold" style="font-size: 0.75rem;">
                                                <i class="ri-chat-3-line me-1"></i> Yorumları Gör
                                            </a>
                                        </td>
                                        <td class="text-center pe-4">
                                            <div class="d-flex justify-content-center gap-2">
                                                <a href="/Blog/BlogDetail/@item.Id" target="_blank" class="btn btn-sm btn-outline-primary rounded-circle p-2 border-0 shadow-sm" title="Sitede Gör">
                                                    <i class="ri-eye-line fs-5"></i>
                                                </a>
                                                <a href="/Admin/Blog/UpdateBlog/@item.Id" class="btn btn-sm btn-outline-info rounded-circle p-2 border-0 shadow-sm" title="Güncelle">
                                                    <i class="ri-edit-2-line fs-5"></i>
                                                </a>
                                                <button onclick="deleteItem('@item.Id','Blog')" class="btn btn-sm btn-outline-danger rounded-circle p-2 border-0 shadow-sm" title="Sil">
                                                    <i class="ri-delete-bin-6-line fs-5"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer bg-white border-top py-3">
                    <p class="mb-0 small text-muted">Toplam <strong>@Model.Count</strong> blog yazısı yayınlandı.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-info {
        background-color: rgba(13, 202, 240, 0.1) !important;
    }

    .bg-soft-primary {
        background-color: rgba(67, 97, 238, 0.1) !important;
    }

    .bg-soft-warning {
        background-color: rgba(255, 193, 7, 0.1) !important;
    }

    .object-fit-cover {
        object-fit: cover;
    }

    .shadow-primary {
        box-shadow: 0 10px 20px rgba(67, 97, 238, 0.2);
    }
</style>

@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 modern-action-card">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between flex-wrap gap-4">

                        <div class="action-header">
                            <div>
                                <h4 class="fw-bold mb-0 text-dark" style="letter-spacing: -0.5px;">Hızlı İşlem Merkezi</h4>
                                <p class="text-muted small mb-0">Yönetim panelindeki en sık kullanılan işlemler.</p>
                            </div>
                        </div>

                        <div class="action-grid">
                            <a href="/Admin/Car/CreateCar/" class="modern-btn m-car">
                                <div class="m-btn-icon">
                                    <i class="ri-taxi-wifi-line"></i>
                                </div>
                                <div class="m-btn-text">
                                    <span>Yeni Araç</span>
                                    <small>Envanter Ekle</small>
                                </div>
                            </a>

                            <a href="/Admin/Brand/CreateBrand/" class="modern-btn m-brand">
                                <div class="m-btn-icon">
                                    <i class="ri-verified-badge-line"></i>
                                </div>
                                <div class="m-btn-text">
                                    <span>Marka Ekle</span>
                                    <small>Filo Markaları</small>
                                </div>
                            </a>

                            <a href="/Admin/Feature/CreateFeature/" class="modern-btn m-feature">
                                <div class="m-btn-icon">
                                    <i class="ri-equalizer-line"></i>
                                </div>
                                <div class="m-btn-text">
                                    <span>Özellik Ekle</span>
                                    <small>Donanım Tanımla</small>
                                </div>
                            </a>

                            <a href="/Admin/Location/CreateLocation/" class="modern-btn m-location">
                                <div class="m-btn-icon">
                                    <i class="ri-map-pin-2-line"></i>
                                </div>
                                <div class="m-btn-text">
                                    <span>Lokasyon</span>
                                    <small>Bölge Yönetimi</small>
                                </div>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @await Component.InvokeAsync("DashboardStatistics")

    <div class="row mt-4">
        <div class="col-lg-6 mb-4">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="fw-bold mb-0 text-dark"><i class="ri-pie-chart-line text-primary me-2"></i>Marka Dağılımı</h6>
                </div>
                <div class="card-body">
                    @await Component.InvokeAsync("DashboardBrandChart")
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-white border-0 py-3">
                    <h6 class="fw-bold mb-0 text-dark"><i class="ri-bar-chart-line text-success me-2"></i>Lokasyon Bazlı Araç Sayısı</h6>
                </div>
                <div class="card-body">
                    @await Component.InvokeAsync("DashboardLocationChart")
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-2">
        <div class="col-12">
            @await Component.InvokeAsync("DashboardLast5Blogs")
        </div>
    </div>
</div>

<style>
    .modern-action-card {
        background: #ffffff;
        border-radius: 20px !important;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.05) !important;
        border: 1px solid #f0f0f0 !important;
    }

    .action-header h4 {
        font-size: 1.4rem;
    }

    .action-grid {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .modern-btn {
        text-decoration: none !important;
        display: flex;
        align-items: center;
        padding: 10px 18px;
        border-radius: 15px;
        min-width: 175px;
        transition: all 0.3s ease;
        border: 1px solid #f1f3f5;
        background: #fff;
    }

    .m-btn-icon {
        width: 40px;
        height: 40px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        margin-right: 12px;
        transition: transform 0.3s ease;
    }

    .m-btn-text {
        display: flex;
        flex-direction: column;
    }

        .m-btn-text span {
            color: #334155;
            font-weight: 700;
            font-size: 0.85rem;
        }

        .m-btn-text small {
            color: #94a3b8;
            font-size: 0.7rem;
        }

    .m-car {
        border-left: 4px solid #4361ee;
    }

        .m-car .m-btn-icon {
            background: #eef2ff;
            color: #4361ee;
        }

    .m-brand {
        border-left: 4px solid #10b981;
    }

        .m-brand .m-btn-icon {
            background: #ecfdf5;
            color: #10b981;
        }

    .m-feature {
        border-left: 4px solid #f59e0b;
    }

        .m-feature .m-btn-icon {
            background: #fffbeb;
            color: #f59e0b;
        }

    .m-location {
        border-left: 4px solid #ef4444;
    }

        .m-location .m-btn-icon {
            background: #fef2f2;
            color: #ef4444;
        }

    .modern-btn:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 15px rgba(0,0,0,0.05);
    }

        .modern-btn:hover .m-btn-icon {
            transform: rotate(-10deg) scale(1.1);
        }

    .m-car:hover {
        background: #f8faff;
    }

    .m-brand:hover {
        background: #f6fdfa;
    }

    .m-feature:hover {
        background: #fffdf5;
    }

    .m-location:hover {
        background: #fffafb;
    }
</style>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

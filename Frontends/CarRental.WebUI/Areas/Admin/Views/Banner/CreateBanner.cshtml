@model CreateBannerDto

@{
    ViewData["Title"] = "Yeni Banner Tanımla";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="alert alert-info border-0 shadow-sm rounded-4 mb-4 d-flex align-items-center gap-3">
                <div class="bg-info p-2 rounded-3 text-white">
                    <i class="ri-lightbulb-line fs-4"></i>
                </div>
                <div>
                    <h6 class="fw-bold mb-0">Tasarım Notu</h6>
                    <small>Burada tanımlayacağınız bilgiler ana sayfanın en üst kısmında, video arka planı ile birlikte görünecektir.</small>
                </div>
            </div>
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-primary-soft p-2 rounded-3 text-primary">
                            <i class="ri-slideshow-view fs-3"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0">Yeni Banner Bilgileri</h5>
                            <small class="text-muted">Lütfen vitrin alanında görünecek metinleri ve video linkini giriniz.</small>
                        </div>
                    </div>
                </div>
                <form asp-area="Admin" asp-controller="Banner" asp-action="CreateBanner" method="post">
                    <div class="card-body p-4 p-md-5">
                        <div class="row g-4">
                            <div class="col-md-12">
                                <label class="form-label fw-bold small text-muted text-uppercase">Banner Başlığı</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-font-size"></i></span>
                                    <input type="text" asp-for="Title" class="form-control border-start-0 py-2 shadow-none" placeholder="Örn: En Lüks Araçları Bizimle Deneyimleyin">
                                </div>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold small text-muted text-uppercase">Banner Açıklaması</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-text"></i></span>
                                    <textarea asp-for="Description" class="form-control border-start-0 py-2 shadow-none" rows="3" placeholder="Kısa ve etkileyici bir açıklama metni giriniz..."></textarea>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Video Alt Başlığı</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-movie-line"></i></span>
                                    <input type="text" asp-for="VideoDescription" class="form-control border-start-0 py-2 shadow-none" placeholder="Örn: Filomuzu Yakından Tanıyın">
                                </div>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Video URL (YouTube/Vimeo)</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-play-circle-line"></i></span>
                                    <input type="text" asp-for="VideoUrl" class="form-control border-start-0 py-2 shadow-none" placeholder="https://youtube.com/watch?v=...">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-light border-top p-4 d-flex justify-content-end gap-2">
                        <a asp-area="Admin" asp-controller="Banner" asp-action="Index" class="btn btn-light rounded-pill px-4 fw-bold">Vazgeç</a>
                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-primary">
                            <i class="ri-save-line me-2"></i> Banner'ı Yayınla
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .input-group-text {
        color: #64748B;
        border-color: #E2E8F0;
    }

    .form-control {
        border-color: #E2E8F0;
        font-size: 0.9rem;
    }

        .form-control:focus {
            border-color: #4361ee;
        }

    .bg-primary-soft {
        background-color: rgba(67, 97, 238, 0.1);
    }

    .shadow-primary {
        box-shadow: 0 10px 20px rgba(67, 97, 238, 0.2);
    }
</style>
@model List<ResultContactDto>

@{
    ViewData["Title"] = "Gelen Mesajlar";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
    int count = 0;

    var sortedModel = Model.OrderBy(x => x.IsRead).ThenByDescending(x => x.SendDate).ToList();
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-primary-soft p-2 rounded-3 text-primary">
                            <i class="ri-mail-unread-fill fs-3"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0 text-dark">İletişim Mesajları</h5>
                            <small class="text-muted">Okunmamış mesajlar en üstte gösterilir.</small>
                        </div>
                    </div>
                    <span class="badge bg-danger rounded-pill px-3" id="unreadCountBadge">
                        @Model.Count(x => !x.IsRead) Yeni Mesaj
                    </span>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 text-muted fw-bold small text-uppercase" style="width: 50px;">#</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase">Durum</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase">Gönderen</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase">Konu</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase">Tarih</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase text-center">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in sortedModel)
                                {
                                    count++;
                                    string rowClass = item.IsRead ? "" : "bg-unread-light";
                                    <tr class="@rowClass" id="row-@item.Id">
                                        <td class="ps-4 fw-medium text-secondary">@count</td>
                                        <td class="status-icon">
                                            @if (!item.IsRead)
                                            {
                                                <span class="badge bg-danger p-1 rounded-circle pulse-red" title="Okunmadı"></span>
                                            }
                                            else
                                            {
                                                <i class="ri-checkbox-circle-fill text-success fs-5" title="Okundu"></i>
                                            }
                                        </td>
                                        <td>
                                            <div class="fw-bold name-text @(item.IsRead ? "text-secondary" : "text-dark")">@item.Name</div>
                                            <small class="text-muted">@item.Email</small>
                                        </td>
                                        <td>
                                            <span class="badge subject-badge @(item.IsRead ? "bg-light text-muted" : "bg-soft-primary text-primary") rounded-pill px-3">
                                                @item.Subject
                                            </span>
                                        </td>
                                        <td>
                                            <div class="small text-secondary">
                                                <i class="ri-time-line me-1"></i> @item.SendDate.ToString("dd.MM.yyyy HH:mm")
                                            </div>
                                        </td>
                                        <td class="text-center pe-4">
                                            <div class="d-flex justify-content-center gap-2">
                                                <button type="button" class="btn btn-sm btn-read-status @(item.IsRead ? "btn-outline-secondary" : "btn-outline-info") rounded-circle p-2 border-0 shadow-sm"
                                                        data-bs-toggle="modal" data-bs-target="#messageModal-@item.Id" title="Mesajı Oku">
                                                    <i class="ri-mail-open-line fs-5"></i>
                                                </button>
                                                <button onclick="deleteItem('@item.Id','Contact')" class="btn btn-sm btn-outline-danger rounded-circle p-2 border-0 shadow-sm" title="Sil">
                                                    <i class="ri-delete-bin-6-line fs-5"></i>
                                                </button>
                                            </div>
                                            <div class="modal fade" id="messageModal-@item.Id" tabindex="-1" aria-hidden="true">
                                                <div class="modal-dialog modal-dialog-centered">
                                                    <div class="modal-content border-0 shadow rounded-4 text-start">
                                                        <div class="modal-header border-bottom py-3">
                                                            <h5 class="modal-title fw-bold">Mesaj Detayı</h5>
                                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                                        </div>
                                                        <div class="modal-body p-4">
                                                            <div class="mb-3">
                                                                <label class="small fw-bold text-muted text-uppercase d-block mb-1">Gönderen</label>
                                                                <p class="mb-0 text-dark fw-medium">@item.Name (@item.Email)</p>
                                                            </div>
                                                            <div class="mb-0">
                                                                <label class="small fw-bold text-muted text-uppercase d-block mb-1">Mesaj</label>
                                                                <div class="bg-light p-3 rounded-3 text-secondary small" style="white-space: pre-wrap;">@item.Message</div>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-unread-light {
        background-color: rgba(67, 97, 238, 0.03);
    }

    .bg-soft-primary {
        background-color: rgba(67, 97, 238, 0.1) !important;
    }

    .bg-primary-soft {
        background-color: rgba(67, 97, 238, 0.1) !important;
    }

    .pulse-red {
        display: inline-block;
        width: 10px;
        height: 10px;
        box-shadow: 0 0 0 rgba(220, 53, 69, 0.4);
        border-radius: 50%;
        animation: pulse-animation 2s infinite;
    }

    @@keyframes pulse-animation {
        0% {
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0.4);
        }

        70% {
            box-shadow: 0 0 0 10px rgba(220, 53, 69, 0);
        }

        100% {
            box-shadow: 0 0 0 0 rgba(220, 53, 69, 0);
        }
    }
</style>

<script>
    async function markAsRead(id) {
        try {
            const response = await fetch(`/Admin/Contact/MarkAsRead/${id}`, {
                method: "POST",
                headers: { "Content-Type": "application/json" }
            });

            if (response.ok) {
                const row = document.getElementById(`row-${id}`);
                if (row && row.classList.contains('bg-unread-light')) {
                    row.classList.remove('bg-unread-light');

                    const statusIcon = row.querySelector('.status-icon');
                    if (statusIcon) statusIcon.innerHTML = '<i class="ri-checkbox-circle-fill text-success fs-5" title="Okundu"></i>';

                    const nameText = row.querySelector('.name-text');
                    if (nameText) {
                        nameText.classList.remove('text-dark');
                        nameText.classList.add('text-secondary');
                    }

                    const badge = row.querySelector('.subject-badge');
                    if (badge) {
                        badge.classList.remove('bg-soft-primary', 'text-primary');
                        badge.classList.add('bg-light', 'text-muted');
                    }

                    const readBtn = row.querySelector('.btn-read-status');
                    if (readBtn) {
                        readBtn.classList.remove('btn-outline-info');
                        readBtn.classList.add('btn-outline-secondary');
                    }
                }
            }
        } catch (error) {
            console.error("Hata:", error);
        }
    }

    document.addEventListener('DOMContentLoaded', function() {
        document.querySelectorAll('[id^="messageModal-"]').forEach(modal => {
            modal.addEventListener('show.bs.modal', function () {
                const id = this.id.split('-')[1];
                markAsRead(id);
            });
        });
    });
</script>
@model UpdateFooterAddressesDto

@{
    ViewData["Title"] = "Adres Bilgilerini Güncelle";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="fw-bold mb-0">İletişim Bilgilerini Düzenle</h5>
                </div>

                <form asp-controller="FooterAddress" asp-action="UpdateFooterAddress" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="card-body p-4 p-md-5">
                        <div class="row g-4">
                            <div class="col-md-12">
                                <label class="form-label fw-bold small text-muted text-uppercase">Kısa Açıklama</label>
                                <textarea asp-for="Description" class="form-control shadow-none" rows="2"></textarea>
                            </div>
                            <div class="col-md-12">
                                <label class="form-label fw-bold small text-muted text-uppercase">Adres</label>
                                <input type="text" asp-for="Address" class="form-control py-2 shadow-none">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Telefon</label>
                                <input type="text" asp-for="Phone" class="form-control py-2 shadow-none">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">E-Posta</label>
                                <input type="email" asp-for="Email" class="form-control py-2 shadow-none">
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-light border-top p-4 d-flex justify-content-end gap-2">
                        <a href="/Admin/FooterAddress/Index" class="btn btn-light rounded-pill px-4 fw-bold text-secondary">İptal</a>
                        <button type="submit" class="btn btn-info text-white rounded-pill px-5 fw-bold shadow-sm">
                            <i class="ri-refresh-line me-2"></i> Değişiklikleri Uygula
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
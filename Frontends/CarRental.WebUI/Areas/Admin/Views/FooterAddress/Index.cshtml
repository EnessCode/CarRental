@model List<ResultFooterAddressesDto>

@{
    ViewData["Title"] = "Kurumsal İletişim Bilgileri";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
    bool hasEntry = Model.Any();
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            @if (hasEntry)
            {
                <div class="alert alert-info border-0 shadow-sm rounded-4 mb-4 d-flex align-items-center gap-3">
                    <div class="bg-info p-2 rounded-3 text-white">
                        <i class="ri-information-line fs-4"></i>
                    </div>
                    <div>
                        <h6 class="fw-bold mb-0">Bilgilendirme</h6>
                        <small>Sistemde halihazırda bir adres tanımı bulunmaktadır. Bilgileri değiştirmek için "Güncelle" butonunu kullanabilirsiniz.</small>
                    </div>
                </div>
            }

            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-0 text-dark">
                            <i class="ri-map-pin-2-fill text-primary me-2"></i> İletişim & Adres Yönetimi
                        </h5>
                        <small class="text-muted">Footer alanında görünecek kurumsal bilgileri tek bir merkezden yönetin.</small>
                    </div>

                    @if (!hasEntry)
                    {
                        <a href="/Admin/FooterAddress/CreateFooterAddress" class="btn btn-primary rounded-pill px-4 d-flex align-items-center gap-2 shadow-primary">
                            <i class="ri-add-circle-line"></i> Yeni Adres Tanımla
                        </a>
                    }
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 text-muted fw-bold small text-uppercase">Adres ve Açıklama</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase">İletişim Kanalları</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase text-center">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (hasEntry)
                                {
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <div class="d-flex align-items-center gap-3">
                                                    <div class="bg-soft-primary p-2 rounded-3 text-primary">
                                                        <i class="ri-building-4-line fs-5"></i>
                                                    </div>
                                                    <div style="max-width: 400px;">
                                                        <div class="fw-bold text-dark">@item.Address</div>
                                                        <small class="text-muted d-block italic mt-1">"@item.Description"</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="small">
                                                    <div class="text-dark mb-1">
                                                        <i class="ri-phone-fill me-2 text-primary"></i>@item.Phone
                                                    </div>
                                                    <div class="text-muted">
                                                        <i class="ri-mail-send-fill me-2 text-primary"></i>@item.Email
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center pe-4">
                                                <div class="d-flex justify-content-center gap-2">
                                                    <a href="/Admin/FooterAddress/UpdateFooterAddress/@item.Id" class="btn btn-sm btn-outline-info rounded-circle p-2 border-0 shadow-sm" title="Bilgileri Düzenle">
                                                        <i class="ri-edit-2-line fs-5"></i>
                                                    </a>
                                                    <button onclick="deleteItem('@item.Id','FooterAddress')" class="btn btn-sm btn-outline-danger rounded-circle p-2 border-0 shadow-sm" title="Adres Kaydını Sil">
                                                        <i class="ri-delete-bin-6-line fs-5"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="3" class="text-center py-5">
                                            <div class="text-muted mb-2">
                                                <i class="ri-map-pin-user-line fs-1 opacity-25"></i>
                                            </div>
                                            <p class="mb-0">Henüz bir adres tanımı yapılmamış.</p>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-soft-primary {
        background-color: rgba(67, 97, 238, 0.1) !important;
    }

    .italic {
        font-style: italic;
    }

    .shadow-primary {
        box-shadow: 0 10px 20px rgba(67, 97, 238, 0.2);
    }
</style>
@model List<ResultReservationDto>

@{
    ViewData["Title"] = "Rezervasyon Listesi";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
    int count = 0;
}

<div class="page-content">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-4">
                            <div class="flex-grow-1">
                                <h4 class="card-title mb-1">Rezervasyon Yönetimi</h4>
                                <p class="text-muted mb-0">Müşteri taleplerini yönetin ve operasyon sürecini takip edin.</p>
                            </div>
                        </div>

                        <div class="table-responsive">
                            <table class="table table-hover align-middle table-nowrap-custom mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 50px;">#</th>
                                        <th>Müşteri Bilgileri</th>
                                        <th>Tarih Aralığı</th>
                                        <th>Güzergah</th>
                                        <th>Toplam Tutar</th>
                                        <th>Durum</th>
                                        <th class="text-end">İşlemler</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        count++;
                                        <tr>
                                            <td class="fw-bold text-muted">@count</td>
                                            <td>
                                                <div class="d-flex flex-column">
                                                    <span class="fw-semibold text-dark">@item.Name @item.Surname</span>
                                                    <small class="text-muted"><i class="ri-phone-line"></i> @item.Phone</small>
                                                    <small class="text-muted"><i class="ri-mail-line"></i> @item.Email</small>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="date-box">
                                                    <div class="text-dark small fw-medium">@item.PickUpDate.ToString("dd.MM.yyyy")</div>
                                                    <div class="text-muted small">@item.DropOffDate.ToString("dd.MM.yyyy")</div>
                                                </div>
                                            </td>
                                            <td>
                                                <div class="location-info">
                                                    <div class="text-truncate" style="max-width: 200px;">
                                                        <i class="ri-map-pin-2-fill text-primary small"></i>
                                                        <span class="small">@item.PickUpLocationName</span>
                                                    </div>
                                                    <div class="text-truncate" style="max-width: 200px;">
                                                        <i class="ri-map-pin-user-fill text-danger small"></i>
                                                        <span class="small">@item.DropOffLocationName</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge bg-light text-dark border p-2">
                                                    @item.TotalPrice.ToString("C2")
                                                </span>
                                            </td>
                                            <td>
                                                @if (item.Status == "Beklemede")
                                                {
                                                    <span class="status-dot bg-warning"></span>
                                            
                                                    <span class="text-warning fw-medium"> @item.Status</span>
                                                }
                                                else if (item.Status == "Onaylandı")
                                                {
                                                    <span class="status-dot bg-success"></span>
                                            
                                                    <span class="text-success fw-medium"> @item.Status</span>
                                                }
                                                else
                                                {
                                                    <span class="status-dot bg-danger"></span>
                                            
                                                    <span class="text-danger fw-medium"> @item.Status</span>
                                                }
                                            </td>
                                            <td class="text-end">
                                                @if (item.Status == "Beklemede")
                                                {
                                                    <div class="btn-group">
                                                        <a href="/Admin/Reservation/ApproveReservation/@item.Id" class="btn btn-sm btn-success px-3">
                                                            Onayla
                                                        </a>
                                                        <a href="/Admin/Reservation/CancelReservation/@item.Id" class="btn btn-sm btn-outline-danger">
                                                            İptal
                                                        </a>
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted small italic">İşlem Tamamlandı</span>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .table-nowrap-custom td {
        white-space: normal; 
        padding: 1rem 0.75rem;
    }

    .status-dot {
        height: 8px;
        width: 8px;
        border-radius: 50%;
        display: inline-block;
        margin-right: 5px;
    }

    .date-box {
        border-left: 2px solid #eff2f7;
        padding-left: 10px;
    }

    .location-info i {
        width: 15px;
        display: inline-block;
    }

    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transition: 0.2s;
    }

    .btn-group .btn {
        border-radius: 4px;
        margin-left: 4px;
    }
</style>
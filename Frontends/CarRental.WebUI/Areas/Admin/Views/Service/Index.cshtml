@model List<ResultServiceDto>

@{
    ViewData["Title"] = "Hizmetlerimiz";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
    int count = 0;
    bool isLimitReached = Model.Count >= 4;
}

<div class="container-fluid py-4">
    @if (isLimitReached)
    {
        <div class="alert alert-warning border-0 shadow-sm rounded-4 mb-4 d-flex align-items-center gap-3">
            <i class="ri-information-line fs-4"></i>
            <div>
                <strong>Hizmet Sınırına Ulaşıldı!</strong> Ana sayfa tasarımı gereği en fazla 4 hizmet gösterebilirsiniz. Yeni eklemek için mevcutlardan birini silmelisiniz.
            </div>
        </div>
    }

    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-0 text-dark">
                            <i class="ri-customer-service-2-fill text-primary me-2"></i> Hizmet Yönetimi
                        </h5>
                        <small class="text-muted">Müşterilere sunduğunuz avantajları yönetin (Maks. 4 Adet).</small>
                    </div>

                    @if (!isLimitReached)
                    {
                        <a href="/Admin/Service/CreateService" class="btn btn-primary rounded-pill px-4 shadow-primary">
                            <i class="ri-add-circle-line"></i> Yeni Hizmet Ekle
                        </a>
                    }
                    else
                    {
                        <button class="btn btn-secondary rounded-pill px-4 opacity-50" disabled>
                            <i class="ri-lock-line"></i> Yeni Ekle (Sınır Dolu)
                        </button>
                    }
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 text-muted fw-bold small text-uppercase" style="width: 80px;">#</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase">İkon</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase">Başlık</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase text-center">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <td class="ps-4 fw-medium text-secondary">@count</td>
                                        <td>
                                            <div class="bg-soft-primary p-2 rounded-3 text-primary d-inline-block">
                                                <i class="@item.IconUrl fs-4"></i>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="fw-bold text-dark">@item.Title</div>
                                            <small class="text-muted text-truncate d-block" style="max-width: 300px;">@item.Description</small>
                                        </td>
                                        <td class="text-center pe-4">
                                            <div class="d-flex justify-content-center gap-2">
                                                <a href="/Admin/Service/UpdateService/@item.Id" class="btn btn-sm btn-outline-info rounded-circle p-2 border-0 shadow-sm">
                                                    <i class="ri-edit-2-line fs-5"></i>
                                                </a>
                                                <button onclick="deleteItem('@item.Id','Service')" class="btn btn-sm btn-outline-danger rounded-circle p-2 border-0 shadow-sm">
                                                    <i class="ri-delete-bin-6-line fs-5"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
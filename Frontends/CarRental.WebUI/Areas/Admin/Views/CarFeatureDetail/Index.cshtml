@model List<ResultCarFeatureByCarIdDto>

@{
    ViewData["Title"] = "Araç Özellik Detayları";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-0 text-dark">
                            <i class="ri-list-settings-line text-primary me-2"></i> Araç Özellik Yönetimi
                        </h5>
                        <small class="text-muted">Araç özelliklerini aktif/pasif hale getirmek için anahtarları kullanabilirsiniz.</small>
                    </div>
                    <a href="/Admin/Car/Index" class="btn btn-outline-secondary rounded-pill px-4">
                        <i class="ri-arrow-left-line"></i> Araç Listesine Dön
                    </a>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <div class="row g-3">
                        @foreach (var item in Model)
                        {
                            <div class="col-md-4 col-sm-6">
                                <div id="feature-card-@item.FeatureId" class="feature-item p-3 rounded-3 border d-flex align-items-center justify-content-between transition-all @(item.Available ? "border-success-subtle bg-light" : "border-light opacity-75")">
                                    <div class="d-flex align-items-center gap-3">
                                        <div id="icon-container-@item.FeatureId" class="feature-icon @(item.Available ? "bg-success" : "bg-secondary") text-white rounded-circle">
                                            <i id="icon-@item.FeatureId" class="@(item.Available ? "ri-check-line" : "ri-close-line")"></i>
                                        </div>
                                        <span id="text-@item.FeatureId" class="fw-medium @(item.Available ? "text-dark" : "text-muted text-decoration-line-through")">
                                            @item.FeatureName
                                        </span>
                                    </div>

                                    <div class="form-check form-switch">
                                        <input class="form-check-input custom-switch" type="checkbox" role="switch"
                                               id="switch-@item.FeatureId"
                                               @(item.Available ? "checked" : "")
                                               onclick="changeStatus(@item.CarId, @item.FeatureId)">
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
                <div class="card-footer bg-white border-top py-3 text-center">
                    <p class="mb-0 small text-muted">Sistemde tanımlı toplam <strong>@Model.Count</strong> özellik listeleniyor.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    function changeStatus(carId, featureId) {
        var isChecked = $("#switch-" + featureId).is(":checked");

        $.ajax({
            url: "/Admin/CarFeatureDetail/ChangeAvailableStatus",
            type: "POST",
            data: {
                carId: carId,
                featureId: featureId,
                status: isChecked
            },
            success: function (response) {
                if (response.success) {
                    var card = $("#feature-card-" + featureId);
                    var iconContainer = $("#icon-container-" + featureId);
                    var icon = $("#icon-" + featureId);
                    var text = $("#text-" + featureId);

                    if (isChecked) {
                        card.removeClass("border-light opacity-75").addClass("border-success-subtle bg-light");
                        iconContainer.removeClass("bg-secondary").addClass("bg-success");
                        icon.removeClass("ri-close-line").addClass("ri-check-line");
                        text.removeClass("text-muted text-decoration-line-through").addClass("text-dark");
                    } else {
                        card.removeClass("border-success-subtle bg-light").addClass("border-light opacity-75");
                        iconContainer.removeClass("bg-success").addClass("bg-secondary");
                        icon.removeClass("ri-check-line").addClass("ri-close-line");
                        text.removeClass("text-dark").addClass("text-muted text-decoration-line-through");
                    }
                }
            },
            error: function () {
                Swal.fire({
                    icon: 'error',
                    title: 'Hata!',
                    text: 'Durum güncellenirken bir hata oluştu.',
                    confirmButtonText: 'Tamam'
                });
                $("#switch-" + featureId).prop("checked", !isChecked);
            }
        });
    }
</script>

<style>
    .feature-item {
        transition: all 0.3s ease;
        min-height: 60px;
    }

    .feature-icon {
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.1rem;
        transition: background-color 0.3s ease;
    }

    .custom-switch {
        width: 2.5em !important;
        height: 1.25em !important;
        cursor: pointer;
    }

        .custom-switch:checked {
            background-color: #198754;
            border-color: #198754;
        }

    .bg-success-subtle {
        background-color: #f0fdf4 !important;
    }

    .transition-all {
        transition: all 0.3s ease;
    }
</style>
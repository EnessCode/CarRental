@model CreateTestimonialDto

@{
    ViewData["Title"] = "Yeni Yorum Ekle";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="fw-bold mb-0">Referans Detaylarını Girin</h5>
                </div>

                <form asp-controller="Testimonial" asp-action="CreateTestimonial" method="post">
                    <div class="card-body p-4 p-md-5">
                        <div class="row g-4">
                            <div class="col-md-4">
                                <label class="form-label fw-bold small text-muted text-uppercase">Ad Soyad</label>
                                <input type="text" asp-for="Name" class="form-control py-2 shadow-none" placeholder="Örn: Ahmet Yılmaz">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold small text-muted text-uppercase">Unvan / Şirket</label>
                                <input type="text" asp-for="Title" class="form-control py-2 shadow-none" placeholder="Örn: CEO, Yazılım Mühendisi">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold small text-muted text-uppercase">Görsel URL</label>
                                <input type="text" asp-for="ImageUrl" class="form-control py-2 shadow-none" placeholder="https://resim-linki.com/p1.jpg">
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold small text-muted text-uppercase">Müşteri Yorumu</label>
                                <textarea asp-for="Comment" class="form-control shadow-none" rows="5" placeholder="Müşterinin kiralama deneyimi hakkındaki düşünceleri..."></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-light border-top p-4 d-flex justify-content-end gap-2">
                        <a href="/Admin/Testimonial/Index" class="btn btn-light rounded-pill px-4 fw-bold text-secondary">Vazgeç</a>
                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-primary">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
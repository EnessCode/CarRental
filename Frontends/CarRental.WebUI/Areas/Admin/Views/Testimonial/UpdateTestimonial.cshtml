@model UpdateTestimonialDto

@{
    ViewData["Title"] = "Yorum Güncelle";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="fw-bold mb-0">Müşteri Geri Bildirimini Düzenle</h5>
                </div>

                <form asp-controller="Testimonial" asp-action="UpdateTestimonial" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="card-body p-4 p-md-5">
                        <div class="row g-4 text-center mb-4">
                            <div class="col-12">
                                <img src="@Model.ImageUrl" class="rounded-circle shadow-sm p-1 border" style="width: 100px; height: 100px; object-fit: cover;">
                            </div>
                        </div>
                        <div class="row g-4">
                            <div class="col-md-4">
                                <label class="form-label fw-bold small text-muted text-uppercase">Ad Soyad</label>
                                <input type="text" asp-for="Name" class="form-control py-2 shadow-none">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold small text-muted text-uppercase">Unvan</label>
                                <input type="text" asp-for="Title" class="form-control py-2 shadow-none">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold small text-muted text-uppercase">Görsel URL</label>
                                <input type="text" asp-for="ImageUrl" class="form-control py-2 shadow-none">
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold small text-muted text-uppercase">Yorum</label>
                                <textarea asp-for="Comment" class="form-control shadow-none" rows="5"></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-light border-top p-4 d-flex justify-content-end gap-2">
                        <a href="/Admin/Testimonial/Index" class="btn btn-light rounded-pill px-4 fw-bold text-secondary">İptal</a>
                        <button type="submit" class="btn btn-info text-white rounded-pill px-5 fw-bold shadow-sm">Değişiklikleri Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
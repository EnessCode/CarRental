@model UpdateBrandDto

@{
    ViewData["Title"] = "Marka Bilgisi Güncelle";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3">
                    <div class="d-flex align-items-center gap-3">
                        <div class="bg-info-soft p-2 rounded-3 text-info">
                            <i class="ri-edit-box-line fs-3"></i>
                        </div>
                        <div>
                            <h5 class="fw-bold mb-0">Marka Bilgilerini Güncelle</h5>
                            <small class="text-muted">ID: #@Model.Id olan marka bilgisini düzenliyorsunuz.</small>
                        </div>
                    </div>
                </div>
                <form method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="card-body p-4 p-md-5">
                        <p class="card-subtitle mb-4 text-secondary">Lütfen güncellemek istediğiniz alanı değiştirin ve "Değişiklikleri Kaydet" butonuna tıklayın.</p>
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Marka Adı</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-car-fill"></i></span>
                                    <input type="text" asp-for="Name" class="form-control border-start-0 py-2 shadow-none">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-light border-top p-4 d-flex justify-content-end gap-2">
                        <a href="/Admin/Brand/Index" class="btn btn-light rounded-pill px-4">Vazgeç</a>
                        <button type="submit" class="btn btn-info text-white rounded-pill px-5 shadow-sm fw-bold">
                            <i class="ri-refresh-line me-2"></i> Değişiklikleri Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-info-soft {
        background-color: rgba(13, 202, 240, 0.1);
    }

    .input-group-text {
        color: #64748B;
        border-color: #E2E8F0;
    }

    .form-control:focus, .form-select:focus {
        border-color: #0dcaf0;
        box-shadow: 0 0 0 0.25rem rgba(13, 202, 240, 0.1);
    }
</style>

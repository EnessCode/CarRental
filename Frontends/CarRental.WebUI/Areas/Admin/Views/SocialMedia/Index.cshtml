@model List<ResultSocialMediaDto>

@{
    ViewData["Title"] = "Sosyal Medya Hesapları";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
    int count = 0;
}

<div class="container-fluid py-4">
    <div class="row">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-0 text-dark">
                            <i class="ri-share-line text-primary me-2"></i> Sosyal Medya Yönetimi
                        </h5>
                        <small class="text-muted">Sitenin footer ve iletişim bölümlerindeki sosyal medya ikonlarını yönetin.</small>
                    </div>
                    <a href="/Admin/SocialMedia/CreateSocialMedia" class="btn btn-primary rounded-pill px-4 d-flex align-items-center gap-2 shadow-primary">
                        <i class="ri-add-circle-line"></i> Yeni Hesap Ekle
                    </a>
                </div>

                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4 py-3 text-muted fw-bold small text-uppercase" style="width: 80px;">#</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase">Platform</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase">Bağlantı (URL)</th>
                                    <th class="py-3 text-muted fw-bold small text-uppercase text-center">İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <td class="ps-4 fw-medium text-secondary">@count</td>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                <div class="bg-soft-primary p-2 rounded-3 text-primary">
                                                    <i class="@item.IconUrl fs-4"></i>
                                                </div>
                                                <span class="fw-bold text-dark">@item.Name</span>
                                            </div>
                                        </td>
                                        <td>
                                            <a href="@item.Url" target="_blank" class="text-muted small text-decoration-none hover-text-primary">
                                                @item.Url <i class="ri-external-link-line ms-1"></i>
                                            </a>
                                        </td>
                                        <td class="text-center pe-4">
                                            <div class="d-flex justify-content-center gap-2">
                                                <a href="/Admin/SocialMedia/UpdateSocialMedia/@item.Id" class="btn btn-sm btn-outline-info rounded-circle p-2 border-0 shadow-sm" title="Güncelle">
                                                    <i class="ri-edit-2-line fs-5"></i>
                                                </a>
                                                <button onclick="deleteItem('@item.Id','SocialMedia')" class="btn btn-sm btn-outline-danger rounded-circle p-2 border-0 shadow-sm" title="Sil">
                                                    <i class="ri-delete-bin-6-line fs-5"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
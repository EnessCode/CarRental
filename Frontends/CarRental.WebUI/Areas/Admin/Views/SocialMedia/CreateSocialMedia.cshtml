@model CreateSocialMediaDto

@{
    ViewData["Title"] = "Yeni Sosyal Medya Hesabı";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="fw-bold mb-0">Sosyal Medya Hesabı Ekle</h5>
                </div>

                <form asp-controller="SocialMedia" asp-action="CreateSocialMedia" method="post">
                    <div class="card-body p-4 p-md-5">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Platform Adı</label>
                                <input type="text" asp-for="Name" class="form-control py-2 shadow-none" placeholder="Örn: Instagram">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Ikon</label>
                                <input type="text" asp-for="IconUrl" class="form-control py-2 shadow-none" placeholder="ri-instagram-line">
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold small text-muted text-uppercase">Profil URL</label>
                                <div class="input-group">
                                    <span class="input-group-text bg-light border-end-0"><i class="ri-link"></i></span>
                                    <input type="text" asp-for="Url" class="form-control border-start-0 py-2 shadow-none" placeholder="https://instagram.com/kullaniciadi">
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-light border-top p-4 d-flex justify-content-end gap-2">
                        <a href="/Admin/SocialMedia/Index" class="btn btn-light rounded-pill px-4 fw-bold text-secondary">Vazgeç</a>
                        <button type="submit" class="btn btn-primary rounded-pill px-5 fw-bold shadow-primary">Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
@model UpdateAuthorDto

@{
    ViewData["Title"] = "Yazar Güncelle";
    Layout = "~/Areas/Admin/Views/Shared/AdminLayout/_AdminLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="card-header bg-white border-bottom py-3">
                    <h5 class="fw-bold mb-0 text-dark"><i class="ri-edit-2-fill text-info me-2"></i>Yazar Profilini Düzenle</h5>
                </div>
                <form method="post">
                    <input type="hidden" asp-for="Id" />
                    <div class="card-body p-4 p-md-5">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Yazar Adı Soyadı</label>
                                <input type="text" asp-for="Name" class="form-control py-2 shadow-none">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-muted text-uppercase">Profil Fotoğraf URL</label>
                                <input type="text" asp-for="ImageUrl" class="form-control py-2 shadow-none">
                            </div>
                            <div class="col-12">
                                <label class="form-label fw-bold small text-muted text-uppercase">Biyografi</label>
                                <textarea asp-for="Description" class="form-control py-2 shadow-none" rows="5"></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-light border-top p-4 d-flex justify-content-end gap-2">
                        <a href="/Admin/Author/Index" class="btn btn-light rounded-pill px-4 fw-bold">İptal</a>
                        <button type="submit" class="btn btn-info text-white rounded-pill px-5 fw-bold">Değişiklikleri Kaydet</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
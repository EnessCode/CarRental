@model List<ResultCommentDto>

    @{
        ViewData["Title"] = "Yorum Yönetimi";
        Layout = "~/Areas/Moderator/Views/Shared/ModeratorLayout/_ModeratorLayout.cshtml";
    }

    <div class="container-fluid py-4">
        <div class="mb-4">
            <h4 class="fw-bold mb-0">Yazılarıma Gelen Yorumlar</h4>
            <p class="text-muted">Okuyucularınızın paylaşımlarınıza bıraktığı geri bildirimler.</p>
        </div>

        <div class="row">
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <div class="col-md-12 mb-3">
                        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                            <div class="card-body p-4">
                                <div class="d-flex justify-content-between align-items-start">
                                    <div class="d-flex gap-3">
                                        <div class="bg-soft-primary text-primary rounded-circle d-flex align-items-center justify-content-center" style="width: 45px; height: 45px;">
                                            <i class="ri-user-smile-line fs-4"></i>
                                        </div>
                                        <div>
                                            <h6 class="fw-bold mb-1">@item.Name</h6>
                                            <p class="text-muted small mb-2">
                                                <i class="ri-article-line me-1"></i> @item.BlogTitle
                                                <span class="mx-2">|</span>
                                                <i class="ri-calendar-line me-1"></i> @item.CreatedDate.ToString("dd MMM yyyy, HH:mm")
                                            </p>
                                            <div class="bg-light p-3 rounded-3 text-dark border-start border-primary border-4">
                                                "@item.Description"
                                            </div>
                                        </div>
                                    </div>
                                    <div class="dropdown">
                                        <button class="btn btn-light btn-sm rounded-pill" type="button" data-bs-toggle="dropdown">
                                            <i class="ri-more-2-fill"></i>
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                            <li><a class="dropdown-item text-danger" href="/Moderator/Comment/DeleteComment/@item.Id" onclick="return confirm('Yorumu silmek istediğinize emin misiniz?')"><i class="ri-delete-bin-line me-2"></i>Yorumu Sil</a></li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <div class="bg-light d-inline-block p-4 rounded-circle mb-3">
                        <i class="ri-chat-history-line fs-1 text-muted"></i>
                    </div>
                    <h5>Henüz yorum yapılmamış</h5>
                    <p class="text-muted">Yazılarınız etkileşim aldığında burada görünecektir.</p>
                </div>
            }
        </div>
    </div>

    <style>
        .bg-soft-primary {
            background-color: rgba(67, 97, 238, 0.1);
        }

        .border-primary {
            border-color: #4361ee !important;
        }
    </style>

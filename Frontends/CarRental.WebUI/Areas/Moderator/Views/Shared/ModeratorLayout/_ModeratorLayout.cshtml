<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>@ViewData["Title"] - Moderatör Paneli</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        :root {
            --mod-bg: #F0F2F5;
            --sidebar-width: 280px;
            --mod-primary: #6366f1; 
            --mod-sidebar: #1e293b;
        }

        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--mod-bg);
            color: #1E293B;
            overflow-x: hidden;
        }

        #page-content-wrapper {
            margin-left: var(--sidebar-width);
            flex: 1;
            min-height: 100vh;
            transition: 0.3s ease;
        }

        .card-modern {
            background: #ffffff;
            border: 1px solid rgba(226, 232, 240, 0.6);
            border-radius: 16px;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        }
    </style>
</head>
<body>
    <div class="d-flex">
        @await Html.PartialAsync("~/Areas/Moderator/Views/Shared/ModeratorLayout/_ModeratorSidebarPartial.cshtml")

        <div id="page-content-wrapper">
            @await Html.PartialAsync("~/Areas/Moderator/Views/Shared/ModeratorLayout/_ModeratorNavbarPartial.cshtml")

            <main class="p-4">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        document.getElementById('menu-toggle')?.addEventListener('click', function() {
            const sidebar = document.getElementById('sidebar-wrapper');
            const content = document.getElementById('page-content-wrapper');
            if (sidebar.style.left === "0px" || sidebar.style.left === "") {
                sidebar.style.left = "-280px";
                content.style.marginLeft = "0";
            } else {
                sidebar.style.left = "0";
                content.style.marginLeft = "280px";
            }
        });
    </script>

    <script>
        function deleteItem(id, controller) {
            Swal.fire({
                title: 'Emin misiniz?',
                text: "Bu içeriği silmek istediğinizden emin misiniz? Bu işlem geri alınamaz!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#ef4444',
                cancelButtonColor: '#64748b', 
                confirmButtonText: 'Evet, Sil!',
                cancelButtonText: 'Vazgeç',
                background: '#ffffff',
                borderRadius: '16px'
            }).then((result) => {
                if (result.isConfirmed) {
                    window.location.href = `/Moderator/${controller}/Delete${controller}/${id}`;
                }
            })
        }
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
@model List<ResultRentACarDto>

@{
    ViewData["Title"] = "Müsait Araçlar";
    Layout = "~/Views/Shared/UILayout/_UILayout.cshtml";
}

<section class="py-5 bg-light position-relative" style="margin-top: 60px;">
    <div class="container">
        <div class="row">
            @if (Model != null && Model.Count > 0)
            {
                @foreach (var item in Model)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                            <img src="@item.CoverImageUrl" class="card-img-top" style="height: 200px; object-fit: cover;">
                            <div class="card-body">
                                <h5 class="card-title fw-bold text-primary">@item.Brand @item.Model</h5>
                                <div class="d-flex justify-content-between mb-3 text-muted small">
                                    <span><i class="ri-settings-3-line"></i> @item.Transmission</span>
                                    <span><i class="ri-gas-station-line"></i> @item.Fuel</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="fs-4 fw-bold text-dark">₺@item.Amount</span>
                                        <span class="text-muted small">/Günlük</span>
                                    </div>
                                    <a href="/Reservation/Index?carId=@item.CarId" class="btn btn-primary rounded-pill px-4">Kirala</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-info w-100 text-center py-5 rounded-4">
                    <i class="ri-information-line fs-1"></i>
                    <p class="mt-3">Aradığınız kriterlere uygun araç bulunamadı.</p>
                </div>
            }
        </div>
    </div>
</section>

@model List<ResultCommentDto>

<div class="pt-5 mt-5">
    <h3 class="mb-5 fw-bold">@Model.Count Yorum</h3>
    <ul class="comment-list list-unstyled">
        @foreach (var item in Model)
        {
            <li class="comment d-flex mb-4 p-4 bg-white rounded-4 shadow-sm">
                <div class="vcard bio me-4 flex-shrink-0">
                    <img src="https://ui-avatars.com/api/?name=@item.Name&background=0D8ABC&color=fff" class="img-fluid rounded-circle" style="width: 60px; height: 60px; object-fit: cover;">
                </div>
                <div class="comment-body w-100">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h4 class="fw-bold mb-0 text-dark" style="font-size: 1.1rem;">@item.Name</h4>
                        <span class="text-muted small">
                            <i class="ri-time-line me-1"></i> @item.CreatedDate.ToString("dd MMMM yyyy, HH:mm")
                        </span>
                    </div>
                    <p class="text-secondary mb-3">@item.Description</p>
                </div>
            </li>
        }
    </ul>
</div>
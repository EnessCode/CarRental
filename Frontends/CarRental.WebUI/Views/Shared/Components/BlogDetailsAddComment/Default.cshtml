<div class="comment-form-wrap pt-5">
    <div class="mb-4 d-flex align-items-center gap-3">
        <div class="bg-primary bg-opacity-10 p-2 rounded-3">
            <i class="ri-chat-smile-3-line fs-4 text-primary"></i>
        </div>
        <h3 class="fw-bold text-dark mb-0">Düşüncelerinizi Paylaşın</h3>
    </div>

    <form action="/Blog/AddComment" method="post" class="p-4 bg-white rounded-4 border border-light shadow-sm">
        <input type="hidden" name="BlogId" value="@ViewBag.blogid" />

        <div class="row g-4">
            <div class="col-12">
                <div class="form-floating custom-form-group">
                    <input type="text" class="form-control border-0 bg-light rounded-3 shadow-none px-4" id="name" name="Name" placeholder="Adınız" required>
                    <label for="name" class="px-4 text-muted small fw-bold text-uppercase">
                        <i class="ri-user-smile-line me-1"></i> Ad Soyad
                    </label>
                </div>
            </div>

            <div class="col-12">
                <div class="form-floating custom-form-group">
                    <textarea class="form-control border-0 bg-light rounded-3 shadow-none px-4" placeholder="Yorum" id="message" name="Description" style="height: 160px; resize: none;" required></textarea>
                    <label for="message" class="px-4 text-muted small fw-bold text-uppercase">
                        <i class="ri-message-3-line me-1"></i> Yorumunuz
                    </label>
                </div>
            </div>

            <div class="col-12 text-end">
                <button type="submit" class="btn btn-primary btn-lg rounded-pill px-5 fw-bold transition-all shadow-sm hover-up">
                    <span class="d-flex align-items-center gap-2">
                        Gönder <i class="ri-send-plane-2-fill"></i>
                    </span>
                </button>
            </div>
        </div>
    </form>
</div>

<style>
    .custom-form-group .form-control {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        border: 2px solid transparent !important;
    }

        .custom-form-group .form-control:focus {
            background-color: #fff !important;
            border-color: rgba(var(--bs-primary-rgb), 0.3) !important;
            box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
        }

    .form-floating > label {
        transition: all 0.2s ease-in-out;
        opacity: 0.8;
    }

    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
        color: var(--bs-primary) !important;
        opacity: 1;
        transform: scale(0.85) translateY(-0.75rem) translateX(0.15rem);
    }

    .hover-up {
        transition: all 0.3s ease;
    }

        .hover-up:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 15px rgba(var(--bs-primary-rgb), 0.3) !important;
        }

    .transition-all {
        transition: all 0.3s ease;
    }

    .bg-light {
        background-color: #f9fbff !important;
    }
</style>